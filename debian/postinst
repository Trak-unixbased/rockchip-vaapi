#!/bin/sh
set -e

. /usr/share/debconf/confmodule

PROFILE_FILE=/etc/profile.d/rockchip-vaapi.sh
ENV_FILE=/etc/environment.d/60-rockchip-vaapi.conf

install_env() {
    # profile.d — terminal sessions and DEs that source login scripts
    cat > "$PROFILE_FILE" << 'EOF'
# Rockchip VA-API hardware video acceleration — managed by rockchip-vaapi package
export LIBVA_DRIVER_NAME=rockchip
export LIBVA_DRIVERS_PATH=/usr/lib/aarch64-linux-gnu/dri
export MOZ_DISABLE_RDD_SANDBOX=1
export MOZ_ENABLE_WAYLAND=1
export MOZ_X11_EGL=1
EOF
    chmod 644 "$PROFILE_FILE"

    # environment.d — systemd user sessions (GNOME, KDE, etc.)
    mkdir -p /etc/environment.d
    cat > "$ENV_FILE" << 'EOF'
# Rockchip VA-API hardware video acceleration — managed by rockchip-vaapi package
LIBVA_DRIVER_NAME=rockchip
LIBVA_DRIVERS_PATH=/usr/lib/aarch64-linux-gnu/dri
MOZ_DISABLE_RDD_SANDBOX=1
MOZ_ENABLE_WAYLAND=1
MOZ_X11_EGL=1
EOF
    chmod 644 "$ENV_FILE"
}

remove_env() {
    rm -f "$PROFILE_FILE" "$ENV_FILE"
}

if [ "$1" = "configure" ] || [ "$1" = "reconfigure" ]; then
    db_get rockchip-vaapi/configure-environment
    if [ "$RET" = "true" ]; then
        install_env
    else
        remove_env
    fi
fi

#DEBHELPER#
